# Email Configuration (Brevo - formerly Sendinblue)
# Get your API key from https://app.brevo.com/settings/account/api
BREVO_API_KEY=your_brevo_api_key_here

# Email from address
FROM_EMAIL=noreply@drivenova.in

# Admin email for notifications
ADMIN_EMAIL=admin@drivenova.in

# Vercel specific
NODE_ENV=production
